@inject IJSRuntime JS
@inject ImageUploadService ImageSvc
@inject BlogAdminOptions Options
@implements IAsyncDisposable

<div class="md-editor-host" @ref="_host"></div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    /// <summary>"wysiwyg" or "markdown" — what mode the editor opens in. Users can toggle either way from the toolbar.</summary>
    [Parameter] public string StartMode { get; set; } = "wysiwyg";
    /// <summary>CSS height passed to Toast UI (e.g. "32rem" or "500px").</summary>
    [Parameter] public string Height { get; set; } = "32rem";

    private ElementReference _host;
    private DotNetObjectReference<MarkdownEditor>? _selfRef;
    private IJSObjectReference? _editorHandle;
    private bool _ready;
    /// <summary>True while we're applying a Value change FROM the parent so we don't loop the change event back at them.</summary>
    private bool _suppressNextChange;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            _editorHandle = await JS.InvokeAsync<IJSObjectReference>(
                "adminCreateRichEditor", _host, Value ?? "", _selfRef,
                new { startMode = StartMode, height = Height });
            _ready = true;
            return;
        }

        // Parent pushed a new Value (e.g. switching between entries on the same Editor page).
        // Push it down to Toast UI if it differs from what the editor currently holds.
        if (_ready && _editorHandle is not null)
        {
            string current = await _editorHandle.InvokeAsync<string>("getMarkdown");
            if (current != (Value ?? ""))
            {
                _suppressNextChange = true;
                await _editorHandle.InvokeVoidAsync("setMarkdown", Value ?? "");
            }
        }
    }

    [JSInvokable]
    public async Task OnEditorChanged(string markdown)
    {
        if (_suppressNextChange)
        {
            _suppressNextChange = false;
            return;
        }
        Value = markdown ?? "";
        await ValueChanged.InvokeAsync(Value);
    }

    /// <summary>
    /// Called from JS when the user drops or selects an image file via the Toast UI toolbar.
    /// <paramref name="base64Bytes"/> is the raw source file Base64-encoded; the upload service
    /// resizes it and commits it to GitHub exactly like a manual upload from the Images page.
    /// Returns the public URL that the editor inserts as the image src.
    /// </summary>
    [JSInvokable]
    public async Task<string> UploadEditorImageAsync(string base64Bytes, string fileName)
    {
        byte[] bytes = Convert.FromBase64String(base64Bytes);
        string folder = Options.ImageFolders.FirstOrDefault() ?? "images";
        return await ImageSvc.UploadRawAsync(bytes, fileName, folder);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_editorHandle is not null)
            {
                await _editorHandle.InvokeVoidAsync("destroy");
                await _editorHandle.DisposeAsync();
            }
        }
        catch
        {
            // Page navigation can tear the JS side down before us; swallow.
        }
        _selfRef?.Dispose();
    }
}

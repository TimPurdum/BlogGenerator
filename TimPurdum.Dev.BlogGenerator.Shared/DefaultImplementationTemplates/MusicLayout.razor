@inherits BaseMusicLayout

<Header NavLinks="NavLinks"></Header>
<main class="page-content" aria-label="content">
    <div class="wrapper">
        <article class="music-entry">
            <header class="music-header">
                <h1 class="music-title">@Title</h1>
                @if (SubTitle is not null)
                {
                    <h2 class="music-subtitle">@SubTitle</h2>
                }
                @if (Date is not null)
                {
                    <p class="music-meta">
                        <time datetime="@Date.Value.ToString("yyyy-MM-dd")">@Date.Value.ToString("MMM dd, yyyy")</time>
                        @if (!string.IsNullOrWhiteSpace(Ensemble))
                        {
                            <span> &middot; @Ensemble</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Role))
                        {
                            <span> &middot; @Role</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Venue))
                        {
                            <span> &middot; @Venue</span>
                        }
                    </p>
                }
            </header>
            @if (!string.IsNullOrWhiteSpace(CoverImage))
            {
                @* Title is MarkupString — using .Value so Razor HTML-encodes the attribute. *@
                <img class="music-cover" src="@CoverImage" alt="@Title.Value" />
            }
            @if (!string.IsNullOrWhiteSpace(EmbedUrl))
            {
                <div class="music-embed">
                    <iframe src="@EmbedUrl" allowfullscreen></iframe>
                </div>
            }
            <div class="music-content">
                @Content
            </div>
        </article>
    </div>
</main>
<Footer></Footer>
